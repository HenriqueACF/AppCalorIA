{
  "expo": {
    "name": "CalorIA",
    "slug": "CalorIA",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "caloria",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.seunome.caloria",
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "Usamos a câmera para fotografar suas refeições e calcular as calorias.",
        "NSPhotoLibraryUsageDescription": "Usamos a galeria para escolher fotos de refeições já registradas."
      }
    },
    "android": {
      "package": "com.seunome.caloria",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para analisar as refeições.",
          "cameraPermission": "O app precisa usar a câmera para fotografar os alimentos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
